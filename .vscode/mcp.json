{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${workspaceFolder}"],
      "description": "Filesystem access for workspace files",
      "enabled": true
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:githubToken}"
      },
      "description": "GitHub integration for repository operations",
      "enabled": false
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Sequential thinking and planning assistance",
      "enabled": true
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Context memory and retention",
      "enabled": true
    },
    "everything": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"],
      "description": "⚠️ DEV ONLY - Comprehensive MCP server for testing",
      "enabled": false,
      "warning": "This is a development/testing server. Not for production use."
    }
  },
  "inputs": {
    "githubToken": {
      "type": "promptString",
      "description": "GitHub Personal Access Token for repository operations",
      "password": true
    }
  },
  "$schema": "https://modelcontextprotocol.io/schemas/mcp-config.schema.json",
  "version": "1.0",
  "notes": [
    "MCP Server Configuration for Uboot",
    "",
    "Setup Instructions:",
    "1. Open VS Code Command Palette (Ctrl+Shift+P)",
    "2. Run: 'MCP: Open User/Workspace Configuration'",
    "3. Enable desired servers (filesystem and sequential-thinking recommended)",
    "",
    "Security Notes:",
    "- Keep npx packages updated (filesystem had advisories in old versions)",
    "- GitHub token only needed if using GitHub integration",
    "- 'everything' server is for development/testing only",
    "",
    "Package Requirements:",
    "- Node.js/npx installed",
    "- MCP-compatible VS Code extension or agent"
  ]
}
