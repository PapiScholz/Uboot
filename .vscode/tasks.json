{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", "${workspaceFolder}",
        "-B", "${workspaceFolder}/build-vs18",
        "-G", "Visual Studio 18 2026",
        "-A", "x64"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "${workspaceFolder}/build-vs18",
        "--config", "Release"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "dependsOn": "cmake: configure"
    },
    {
      "label": "python: run GUI",
      "type": "shell",
      "command": "if (Test-Path '.\\.venv\\Scripts\\python.exe') { & '.\\.venv\\Scripts\\python.exe' -m app.main } else { python -m app.main }",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "python: run tests",
      "type": "shell",
      "command": "if (Test-Path '.\\.venv\\Scripts\\python.exe') { & '.\\.venv\\Scripts\\python.exe' -m pytest tests/smoke_tests.py -v } else { python -m pytest tests/smoke_tests.py -v }",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "sign: uboot-core",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/scripts/windows/sign-file.ps1",
        "-FilePath", "${workspaceFolder}/build-vs18/bin/Release/uboot-core.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": []
    }
  ]
}
