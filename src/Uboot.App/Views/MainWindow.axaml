<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Uboot.App.ViewModels"
        x:Class="Uboot.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Uboot - Ultra-Conservative Autoruns Analysis"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Margin="10">
    
    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
      <Button Content="{Binding CurrentLanguage, StringFormat='Scan ({0})', FallbackValue='Scan'}" 
              Command="{Binding ScanCommand}"
              IsEnabled="{Binding !IsScanning}"
              HotKey="F5" />
      
      <Button Content="Create Baseline" 
              Command="{Binding CreateBaselineCommand}"
              IsEnabled="{Binding !IsScanning}" />
      
      <Separator Width="1" Height="30" />
      
      <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" />
      <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" />
      <Button Content="Export MD" Command="{Binding ExportMarkdownCommand}" />
      
      <Separator Width="1" Height="30" />
      
      <CheckBox Content="Online Mode (VirusTotal/WHOIS/DNS)" 
                IsChecked="{Binding OnlineEnabled}"
                ToolTip.Tip="OFFLINE by default. Enable for VirusTotal, WHOIS, DNS lookups." />
      
      <CheckBox Content="SHA512" 
                IsChecked="{Binding IncludeSha512}"
                ToolTip.Tip="Include SHA512 hashes (slower)" />
      
      <Button Content="{Binding CurrentLanguage}" 
              Command="{Binding ToggleLanguageCommand}"
              ToolTip.Tip="Toggle Language (EN/ES)" />
    </StackPanel>

    <!-- Main Content -->
    <Grid Grid.Row="1" ColumnDefinitions="2*,*">
      
      <!-- Entries List -->
      <DataGrid Grid.Column="0" 
                ItemsSource="{Binding Entries}"
                SelectedItem="{Binding SelectedEntry}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="All"
                Margin="0,0,5,0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
          <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="60" />
          <DataGridTextColumn Header="Entry Name" Binding="{Binding EntryName}" Width="200" />
          <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="300" />
          <DataGridTextColumn Header="Classification" Binding="{Binding Finding.Classification}" Width="100" />
          <DataGridTextColumn Header="Confidence" Binding="{Binding Finding.Confidence, StringFormat='{}{0:F2}'}" Width="80" />
          <DataGridTextColumn Header="Signed" Binding="{Binding IsSigned}" Width="60" />
          <DataGridTextColumn Header="Diff" Binding="{Binding DiffState}" Width="80" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Detail Panel -->
      <Border Grid.Column="1" 
              BorderBrush="Gray" 
              BorderThickness="1" 
              Padding="10"
              Margin="5,0,0,0">
        <ScrollViewer>
          <StackPanel Spacing="10" IsVisible="{Binding SelectedEntry, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Text="Entry Details" FontWeight="Bold" FontSize="16" />
            
            <TextBlock Text="{Binding SelectedEntry.EntryName, StringFormat='Name: {0}'}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedEntry.Source, StringFormat='Source: {0}'}" />
            <TextBlock Text="{Binding SelectedEntry.Location, StringFormat='Location: {0}'}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedEntry.Command, StringFormat='Command: {0}'}" TextWrapping="Wrap" />
            
            <Separator />
            
            <TextBlock Text="Classification" FontWeight="Bold" />
            <TextBlock Text="{Binding SelectedEntry.Finding.Classification}" />
            <TextBlock Text="{Binding SelectedEntry.Finding.Confidence, StringFormat='Confidence: {0:F2}'}" />
            
            <TextBlock Text="Evidence:" FontWeight="Bold" Margin="0,10,0,0" />
            <ItemsControl ItemsSource="{Binding SelectedEntry.Finding.Evidence}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,5">
                    <TextBlock Text="{Binding RuleId}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Weight, StringFormat='Weight: {0:F2}'}" FontSize="11" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <Separator />
            
            <TextBlock Text="Hashes" FontWeight="Bold" />
            <TextBlock Text="{Binding SelectedEntry.MD5, StringFormat='MD5: {0}'}" FontSize="11" TextWrapping="Wrap" />
            <TextBlock Text="{Binding SelectedEntry.SHA256, StringFormat='SHA256: {0}'}" FontSize="11" TextWrapping="Wrap" />
            
            <Separator />
            
            <TextBlock Text="Signature" FontWeight="Bold" />
            <TextBlock Text="{Binding SelectedEntry.IsSigned, StringFormat='Signed: {0}'}" />
            <TextBlock Text="{Binding SelectedEntry.SignatureValid, StringFormat='Valid: {0}'}" />
            <TextBlock Text="{Binding SelectedEntry.SignerSubject, StringFormat='Subject: {0}'}" TextWrapping="Wrap" />
            
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2" 
            Background="#F0F0F0" 
            Padding="10,5"
            Margin="0,10,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" />
        <ProgressBar Grid.Column="1" 
                     IsIndeterminate="True" 
                     IsVisible="{Binding IsScanning}"
                     Width="150" 
                     Height="20" />
      </Grid>
    </Border>

  </Grid>
</Window>
